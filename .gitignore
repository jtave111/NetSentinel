# ── Next.js / Node.js ────────────────────────────────────────
NetSentinel.Web/.next/
NetSentinel.Web/out/
NetSentinel.Web/build/
NetSentinel.Web/dist/

# Dependencies
NetSentinel.Web/node_modules/
NetSentinel.Web/.pnp
NetSentinel.Web/.pnp.js
NetSentinel.Web/.yarn/install-state.gz

# Environment variables
NetSentinel.Web/.env*.local
NetSentinel.Web/.env.production
NetSentinel.Api/appsettings.Development.json

# TypeScript
NetSentinel.Web/*.tsbuildinfo
NetSentinel.Web/next-env.d.ts

# Testing
NetSentinel.Web/coverage/

# Vercel / Deployment
NetSentinel.Web/.vercel

# ── Databases ────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

